# Copy to .env and fill in values for local development.
# .env is loaded automatically by the adapter on startup (via godotenv).

# Infrastructure (sensitive — get from a team member or the dev AWS secret)
DATABASE_URL=postgres://checker:checker@localhost/db_checker?sslmode=disable
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# General
ENV=dev
LOG_LEVEL=debug
AWS_REGION=us-east-2
