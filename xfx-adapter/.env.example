# Copy to .env and fill in values for local development.
# .env is loaded automatically by the adapter on startup (via godotenv).

# Infrastructure (sensitive — get from a team member or the dev AWS secret)
DATABASE_URL=postgres://checker:checker@localhost/db_checker?sslmode=disable
REDIS_URL=redis://localhost:6379
NATS_URL=nats://localhost:4222

# XFX Auth0 (non-sensitive — dev sandbox values are safe to share)
AUTH0_ENDPOINT=https://dev-er8o7vv4aka08m70.us.auth0.com/oauth/token
AUTH0_AUDIENCE=https://dev.xfx.io

# General
ENV=dev
LOG_LEVEL=debug
AWS_REGION=us-east-2
