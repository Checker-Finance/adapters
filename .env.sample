# Copy this file to .env and fill in the values for the target environment.
# All other config (DATABASE_URL, REDIS_URL, NATS_URL, API keys, etc.) is
# resolved from AWS Secrets Manager at runtime using ENV + AWS_REGION.

# Required on every EC2 host
ENV=dev                   # dev | prod
AWS_REGION=us-east-2

# XFX adapter — not in SM secret; must be set here (or added to prod/xfx-adapter SM secret)
AUTH0_ENDPOINT=https://dev-er8o7vv4aka08m70.us.auth0.com/oauth/token
AUTH0_AUDIENCE=https://api.xfx.io/trading
